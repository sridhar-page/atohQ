// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

enum TokenStatus {
  WAITING
  SERVING
  COMPLETED
  NO_SHOW
  CANCELLED
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  queues      Queue[]
  tokens      Token[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Queue {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tokens      Token[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Token {
  id             String      @id @default(uuid())
  tokenNumber    String      // e.g., A-101
  patientName    String
  patientPhone   String
  status         TokenStatus @default(WAITING)
  priority       Int         @default(0) // Higher is more urgent
  queueId        String
  queue          Queue       @relation(fields: [queueId], references: [id])
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  calledAt       DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId, queueId, status])
}
