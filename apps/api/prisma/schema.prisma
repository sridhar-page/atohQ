generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  queues    Queue[]
  tokens    Token[]
  users     User[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default("RECEPTIONIST")
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Queue {
  id              String   @id @default(uuid())
  name            String
  description     String?
  roomNumber      String?
  isActive        Boolean  @default(true)
  maxTokensPerDay Int      @default(100)
  startTime       String   @default("09:00")
  endTime         String   @default("17:00")
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  tokens          Token[]
}

model Token {
  id           String      @id @default(uuid())
  tokenNumber  String
  patientName  String
  patientPhone String
  status       TokenStatus @default("WAITING")
  priority     Int         @default(0)
  queueId      String
  tenantId     String
  calledAt     DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  queue        Queue       @relation(fields: [queueId], references: [id])

  @@index([tenantId, queueId, status])
}

enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

enum TokenStatus {
  WAITING
  SERVING
  COMPLETED
  NO_SHOW
  CANCELLED
}
