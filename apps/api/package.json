{
  "name": "api",
  "version": "0.0.1",
  "description": "Express.js Backend for Q-Ease",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run prisma:push && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npm run prisma:generate && npm run prisma:push && npm run db:seed"
  },
  "dependencies": {
    "prisma": "^7.5.0",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
